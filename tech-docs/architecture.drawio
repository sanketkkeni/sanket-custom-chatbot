<mxfile host="app.diagrams.net"><diagram id="arch" name="Architecture"><mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="title" value="Sanket Custom Chatbot - System Architecture" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=20;fontStyle=1" vertex="1" parent="1"><mxGeometry x="320" y="10" width="560" height="40" as="geometry" /></mxCell><mxCell id="browser_box" value="Browser" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;dashPattern=1 1;fillColor=#E8F4FD;strokeColor=#4A90D9;fontSize=14;fontStyle=1;verticalAlign=top" vertex="1" parent="1"><mxGeometry x="20" y="70" width="260" height="160" as="geometry" /></mxCell><mxCell id="browser_nextjs" value="Next.js SPA&lt;br&gt;(Next 14 + React 18)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4A90D9" vertex="1" parent="1"><mxGeometry x="40" y="120" width="100" height="50" as="geometry" /></mxCell><mxCell id="browser_cognito" value="Cognito SDK&lt;br&gt;(auth lib)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4A90D9" vertex="1" parent="1"><mxGeometry x="160" y="120" width="100" height="50" as="geometry" /></mxCell><mxCell id="vercel_box" value="Vercel (CDN + SSR)" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;dashPattern=1 1;fillColor=#F0E6FF;strokeColor=#7B2CBF;fontSize=14;fontStyle=1;verticalAlign=top" vertex="1" parent="1"><mxGeometry x="320" y="70" width="200" height="160" as="geometry" /></mxCell><mxCell id="vercel_next" value="Next.js 14 SSR&lt;br&gt;Pages Router" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7B2CBF" vertex="1" parent="1"><mxGeometry x="350" y="110" width="140" height="45" as="geometry" /></mxCell><mxCell id="aws_box" value="AWS Cloud (us-east-1)" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;dashPattern=1 1;fillColor=#FFF3E0;strokeColor=#E67E22;fontSize=14;fontStyle=1;verticalAlign=top" vertex="1" parent="1"><mxGeometry x="560" y="60" width="620" height="820" as="geometry" /></mxCell><mxCell id="cognito_box" value="Cognito User Pool&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;USER_PASSWORD_AUTH&lt;br&gt;Email-based auth&lt;br&gt;JWT tokens (1h access + 30d refresh)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E67E22" vertex="1" parent="1"><mxGeometry x="580" y="100" width="240" height="110" as="geometry" /></mxCell><mxCell id="apigw_box" value="API Gateway HTTP API v2&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Routes:&lt;br&gt;GET/POST /kbs, /kbs/{id}&lt;br&gt;DELETE /kbs/{id}, /kbs/{id}/files/{file}&lt;br&gt;POST /kbs/{id}/upload, /sync&lt;br&gt;GET /kbs/{id}/files, /sync, /stats&lt;br&gt;POST /chat&lt;br&gt;GET/DELETE /history, /history/{id}&lt;br&gt;OPTIONS /{proxy} (CORS)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32" vertex="1" parent="1"><mxGeometry x="580" y="240" width="250" height="140" as="geometry" /></mxCell><mxCell id="lambda_kb" value="kb_api.py&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;KB Management Lambda&lt;br&gt;10 route handlers&lt;br&gt;KB CRUD, file mgmt, sync&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0" vertex="1" parent="1"><mxGeometry x="580" y="410" width="180" height="70" as="geometry" /></mxCell><mxCell id="lambda_chat" value="chat_handler.py&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;RAG Chat Lambda&lt;br&gt;RetrieveAndGenerate&lt;br&gt;History persistence&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0" vertex="1" parent="1"><mxGeometry x="580" y="500" width="180" height="70" as="geometry" /></mxCell><mxCell id="lambda_history" value="history_handler.py&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;History Lambda&lt;br&gt;List/search conversations&lt;br&gt;Read/delete MD content&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0" vertex="1" parent="1"><mxGeometry x="580" y="590" width="180" height="70" as="geometry" /></mxCell><mxCell id="dynamo_box" value="DynamoDB&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;kbs table:&lt;/b&gt;&lt;br&gt;userId(HASH) + kbId(SORT)&lt;br&gt;status, bedrockKbId, docCount&lt;br&gt;lastSyncStatus, vectorIndexArn&lt;br&gt;GSI: bedrockKbId-index&lt;br&gt;&lt;br&gt;&lt;b&gt;agents table:&lt;/b&gt;&lt;br&gt;userId(HASH) + agentId(SORT)&lt;br&gt;kbId, name, instructions&lt;br&gt;GSI: kbId-index&lt;br&gt;&lt;br&gt;&lt;b&gt;conversations table:&lt;/b&gt;&lt;br&gt;userId(HASH) + convId(SORT)&lt;br&gt;kbId, title, s3Key, msgCount&lt;br&gt;GSIs: kbId-index, agentId-index&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCC80;strokeColor=#E65100" vertex="1" parent="1"><mxGeometry x="860" y="240" width="290" height="245" as="geometry" /></mxCell><mxCell id="s3_box" value="S3 Buckets&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Documents Bucket:&lt;/b&gt;&lt;br&gt;users/{uid}/kbs/{kbId}/{files}&lt;br&gt;PDF, TXT, MD, HTML, CSV, DOC, XLS&lt;br&gt;Versioned, AES-256, CORS enabled&lt;br&gt;&lt;br&gt;&lt;b&gt;History Bucket:&lt;/b&gt;&lt;br&gt;users/{uid}/conversations/{convId}.md&lt;br&gt;Markdown + YAML frontmatter&lt;br&gt;Versioned, AES-256&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEDC8;strokeColor=#33691E" vertex="1" parent="1"><mxGeometry x="860" y="510" width="290" height="150" as="geometry" /></mxCell><mxCell id="bedrock_box" value="Bedrock&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Knowledge Base: VECTOR type&lt;/b&gt;&lt;br&gt;Titan Text Embeddings v2&lt;br&gt;S3 Vectors storage&lt;br&gt;&lt;br&gt;&lt;b&gt;Data Source (per KB):&lt;/b&gt;&lt;br&gt;SEMANTIC chunking (95/0/512)&lt;br&gt;BEDROCK FoundationModel parsing&lt;br&gt;Claude Haiku 4.5 inference profile&lt;br&gt;dataDeletionPolicy: RETAIN&lt;br&gt;&lt;br&gt;&lt;b&gt;RetrieveAndGenerate:&lt;/b&gt;&lt;br&gt;KNOWLEDGE_BASE type&lt;br&gt;$search_results$ template&lt;br&gt;Citations with source dedup&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#880E4F" vertex="1" parent="1"><mxGeometry x="860" y="680" width="290" height="175" as="geometry" /></mxCell><mxCell id="vectors" value="S3 Vectors&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Vector Bucket: bedrock-chat-vectors&lt;br&gt;Index: idx-{kbId}&lt;br&gt;float32, 1024d, euclidean&lt;br&gt;Non-filterable: AMAZON_BEDROCK_TEXT&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1C4E9;strokeColor=#4527A0" vertex="1" parent="1"><mxGeometry x="580" y="710" width="180" height="85" as="geometry" /></mxCell><mxCell id="legend" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;--- Request/API call&lt;br&gt;- - - Presigned upload (bypass)&lt;br&gt;&lt;font color=&quot;#E67E22&quot;&gt;--- Auth flow (Cognito SDK)&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#880E4F&quot;&gt;--- Bedrock API calls&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999" vertex="1" parent="1"><mxGeometry x="20" y="260" width="250" height="120" as="geometry" /></mxCell><mxCell id="deploy_box" value="&lt;b&gt;Deployment&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Frontend: Vercel (auto from GitHub)&lt;br&gt;Backend: Terraform Cloud + AWS CLI&lt;br&gt;Lambda updates: build.ps1 -&gt; update-function-code&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;dashPattern=1 1;fillColor=#E0F2F1;strokeColor=#00695C" vertex="1" parent="1"><mxGeometry x="20" y="410" width="250" height="100" as="geometry" /></mxCell><mxCell id="c1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#333;dashed=1;dashPattern=1 1" edge="1" parent="1" source="browser_nextjs" target="vercel_next"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="c2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#E67E22;strokeWidth=2" edge="1" parent="1" source="browser_cognito" target="cognito_box"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="320" y="130" /><mxPoint x="420" y="130" /><mxPoint x="420" y="155" /><mxPoint x="580" y="155" /></Array></mxGeometry></mxCell><mxCell id="c3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#333;strokeWidth=2" edge="1" parent="1" source="vercel_next" target="apigw_box"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="560" y="133" /><mxPoint x="520" y="310" /><mxPoint x="580" y="310" /></Array></mxGeometry></mxCell><mxCell id="c4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#1565C0" edge="1" parent="1" source="apigw_box" target="lambda_kb"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="c5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.25;exitY=1;entryX=0.5;entryY=0;strokeColor=#1565C0" edge="1" parent="1" source="apigw_box" target="lambda_chat"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="c6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.1;exitY=1;entryX=0.5;entryY=0;strokeColor=#1565C0" edge="1" parent="1" source="apigw_box" target="lambda_history"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="c7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.3;entryX=0;entryY=0.2;strokeColor=#333" edge="1" parent="1" source="lambda_kb" target="dynamo_box"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="c8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.6;entryX=0;entryY=0.3;st